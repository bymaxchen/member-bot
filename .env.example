# ====== 云 MySQL 连接串 ======
# 格式: mysql://user:password@host:port/database
# 大部分云 MySQL 支持，PlanetScale 之类要求 SSL 时加 ?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://user:password@your-host:3306/membership

# ====== 价格 → 会员类型映射（涨价时改这里） ======
MONTHLY_PRICE=29
LIFETIME_PRICE=119

# ====== 调度 ======
# 默认每 5 分钟一次
SCRAPE_CRON=*/5 * * * *

# ====== Cookie 初次 bootstrap ======
# 首次跑会从这个文件读 cookies → 写进 DB
# 之后这个文件就没用了，DB 是唯一来源
COOKIE_FILE=./data/cookies.json

# ====== 日志 ======
LOG_LEVEL=info
NODE_ENV=development
