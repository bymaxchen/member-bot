# ====== 云 MySQL 连接串 ======
# 格式: mysql://user:password@host:port/database
# TiDB Cloud Serverless / PlanetScale / 阿里云 RDS 等强制 TLS 的服务直接用即可,
# 默认开启 SSL (Node.js 用 Mozilla CA 信任 Let's Encrypt)。
# 本地 MySQL 没 SSL 时,加一行 DB_SSL=false 关掉。
DATABASE_URL=mysql://user:password@your-host:4000/membership
# DB_SSL=false

# ====== 价格 → 会员类型映射（涨价时改这里） ======
MONTHLY_PRICE=29
LIFETIME_PRICE=119

# ====== 调度 ======
# 爬虫: 默认每 5 分钟一次
SCRAPE_CRON=*/5 * * * *
# 日常任务 (续费检测/到期提醒/过期清理): 默认每天 10:00
DAILY_CRON=0 10 * * *

# ====== Telegram Bot ======
TG_BOT_TOKEN=
TG_CHANNEL_ID=
# 多个 admin 逗号分隔
TG_ADMIN_IDS=
# DM 提醒里附上的 Fansky 续费链接 (你的会员订阅页 URL)
FANSKY_SUBSCRIBE_URL=https://www.fansky.net/
# 群主联系方式 (会出现在 /start 文案里, 例: @your_handle), 不配则显示"群主"
OWNER_CONTACT=

# ====== Cookie 初次 bootstrap ======
COOKIE_FILE=./data/cookies.json

# ====== 日志 ======
LOG_LEVEL=info
NODE_ENV=development
